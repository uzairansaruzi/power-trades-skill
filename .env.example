# PowerTrades — Required API Keys
# Copy this file to .env and fill in your keys.
#
# All APIs below have free tiers sufficient for day trading use.

# Finnhub — Real-time quotes, news, earnings calendar
# Sign up: https://finnhub.io/register
# Free tier: 60 calls/min
FINNHUB_API_KEY=

# Alpha Vantage — Pre-computed technical indicators (RSI, MACD, EMA, VWAP)
# Sign up: https://www.alphavantage.co/support/#api-key
# Free tier: 25 calls/day
ALPHA_VANTAGE_API_KEY=

# FRED — Federal Reserve economic data (interest rates, CPI, unemployment)
# Sign up: https://fred.stlouisfed.org/docs/api/api_key.html
# Free tier: 120 calls/min
FRED_API_KEY=

# Polygon.io — Market data, aggregated bars, options snapshots
# Sign up: https://polygon.io/dashboard/signup
# Free tier: 5 calls/min (delayed data)
POLYGON_API_KEY=

# ─── Optional ────────────────────────────────────────────────────

# Yahoo Finance (yfinance) does NOT require an API key.
# It is installed as a Python dependency: pip install yfinance
